# Intern·vention — environment template. Copy to .env.local and fill in.
# (.env.local is gitignored; this template is committed.)

# ── Supabase Postgres ────────────────────────────────────────────────
# Copy BOTH strings from the Supabase dashboard → Project → Connect.
# Do NOT use the deprecated db.<ref>.supabase.co host (IPv4-deprecated).
#
# DATABASE_URL = Supavisor *transaction* pooler (port 6543) for app runtime.
#   Must include ?pgbouncer=true&connection_limit=1 (Prisma over PgBouncer).
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL = Supavisor *session* pooler (port 5432) for Prisma migrations.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Auth.js (NextAuth v5) ────────────────────────────────────────────
# AUTH_SECRET: generate with `openssl rand -base64 32`
AUTH_SECRET=""
# AUTH_URL: http://localhost:3000 in dev; the deployed origin in prod.
AUTH_URL="http://localhost:3000"

# ── Google OAuth (Stanford SUNet; owner already created the client) ──
# Authorized redirect URI must include:
#   http://localhost:3000/api/auth/callback/google  (dev)
#   https://<your-domain>/api/auth/callback/google  (prod)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── logo.dev (publishable key; safe to expose client-side) ───────────
# The prototype's public token can be reused (DESIGN_TOKENS.md).
NEXT_PUBLIC_LOGO_DEV_TOKEN="pk_GPjIAuXNTVmwfUsjmuW2gA"
